#!/command/with-contenv sh
# FFW LG2 Leader AI service finish script
# This script runs when the service is stopped.
# It receives the exit code of the run script as $1.

set -e

# Log the finish event for debugging
EXIT_CODE=${1:-unknown}
echo "[ffw_lg2_leader_ai finish] Service stopped with exit code $EXIT_CODE"

# If we recorded a process group ID, send a final graceful SIGTERM to that group
# and wait until the processes are fully dead (or a timeout is reached).
PGID_FILE=/run/ffw_lg2_leader_ai.pgid
if [ -f "${PGID_FILE}" ]; then
    PGID=$(cat "${PGID_FILE}" 2>/dev/null || echo "")
    if [ -n "${PGID}" ]; then
        echo "[ffw_lg2_leader_ai finish] Sending SIGTERM to process group ${PGID}"
        # Negative PGID means "entire process group" to kill(2)
        kill -TERM -"${PGID}" 2>/dev/null || echo "[ffw_lg2_leader_ai finish] Warning: kill -TERM -${PGID} failed or group already gone"

        # Wait until the process group is gone, with a hard timeout
        TIMEOUT=30        # total seconds to wait
        SLEEP_INTERVAL=1  # seconds between checks
        ELAPSED=0

        # Helper: returns 0 if PGID still has processes, 1 otherwise
        pgid_alive() {
            # 'ps -o pgid=' prints the PGID for each matching process;
            # if there is at least one line, the group is still alive.
            ps -o pgid= -g "${PGID}" 2>/dev/null | grep -q .
        }

        if pgid_alive; then
            echo "[ffw_lg2_leader_ai finish] Waiting for process group ${PGID} to exit (timeout: ${TIMEOUT}s)..."
        fi

        while pgid_alive && [ "${ELAPSED}" -lt "${TIMEOUT}" ]; do
            sleep "${SLEEP_INTERVAL}"
            ELAPSED=$((ELAPSED + SLEEP_INTERVAL))
        done

        if pgid_alive; then
            echo "[ffw_lg2_leader_ai finish] Timeout waiting for process group ${PGID} to exit; sending SIGKILL"
            kill -KILL -"${PGID}" 2>/dev/null || echo "[ffw_lg2_leader_ai finish] Warning: kill -KILL -${PGID} failed or group already gone"
        else
            echo "[ffw_lg2_leader_ai finish] Process group ${PGID} fully exited after ${ELAPSED}s"
        fi
    fi
fi

echo "[ffw_lg2_leader_ai finish] Finish script completed"

exit 0
